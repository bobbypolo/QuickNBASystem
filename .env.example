# Optional: The Odds API for live lines (not required - default lines are pre-loaded)
# THE_ODDS_API_KEY=your_key_here
# REQUIRE_LIVE_ODDS=true
# MIN_LIVE_ODDS_COVERAGE=0.90

# Optional: NBA API (nba_api) works without a key - public endpoints only
# No key required for nba_api

# Supabase integration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
